    "metadata_definitions": {
        "CulturalMotif": "Core abstract class representing high-level regional cultural design elements.",
        "ClassificationDimension": "The root abstract class representing the structural parameters used to analyze a motif's overall design form.",
        "CompositionalComplexity": "The structural parameter within the classification dimension that evaluates the number and hierarchy of design parts forming a motif.",
        "GeometricStructure": "The structural parameter within the classification dimension that evaluates the spatial layout and symmetry of design parts forming a motif.",
        "AinuMotif": "Traditional design motifs originating from the indigenous Ainu culture of Hokkaido.",
        "RyukyuMotif": "Traditional design motifs originating from the historical Ryukyu Kingdom of Okinawa.",
        "ElementaryMotif": "An irreducible, single-element primitive design unit.",
        "SyntheticMotif": "A compound pattern formed by combining multiple elementary primitives.",
        "CombinatorialMotif": "A multi-layered pattern expanding on traditional rules, elementary and synthetic motifs.",
        "SymmetricalGeometry": "A layout displaying clear mathematical reflection, rotation, or translation symmetry.",
        "AsymmetricalGeometry": "A layout governed by organic, non-uniform, or balanced asymmetrical spatial constraints.",
        "IPCM_Online_System": "Automated platform for point cloud generation.",
        "OpenSCAD_Template": "Template for rendering point clouds to digital abstractions using OpenSCAD."
    },
