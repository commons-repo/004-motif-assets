<owl:AnnotationProperty rdf:about="#classDefinition"/>

<owl:AnnotationProperty rdf:about="#subclassDefinition"/>

<owl:AnnotationProperty rdf:about="#dimensionDefinition"/>

<owl:Class rdf:about="#CulturalMotif">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <classDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Core abstract class representing high-level regional cultural design elements.</classDefinition>
</owl:Class>

<owl:Class rdf:about="#AinuMotif">
  <rdfs:subClassOf rdf:resource="#CulturalMotif"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Traditional design motifs originating from the indigenous Ainu culture of Hokkaido.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#RyukyuMotif">
  <rdfs:subClassOf rdf:resource="#CulturalMotif"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Traditional design motifs originating from the historical Ryukyu Kingdom of Okinawa.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#ClassificationDimension">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <dimensionDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The root abstract class representing the structural parameters used to analyze a motif's overall design form.</dimensionDefinition>
</owl:Class>

<owl:Class rdf:about="#CompositionalComplexity">
  <rdfs:subClassOf rdf:resource="#ClassificationDimension"/>
  <classDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The structural parameter within the classification dimension that evaluates the number and hierarchy of design parts forming a motif.</classDefinition>
</owl:Class>

<owl:Class rdf:about="#GeometricStructure">
  <rdfs:subClassOf rdf:resource="#ClassificationDimension"/>
  <classDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The structural parameter within the classification dimension that evaluates the spatial layout and symmetry of design parts forming a motif.</classDefinition>
</owl:Class>

<owl:Class rdf:about="#ElementaryMotif">
  <rdfs:subClassOf rdf:resource="#CompositionalComplexity"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An irreducible, single-element primitive design unit.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#SyntheticMotif">
  <rdfs:subClassOf rdf:resource="#CompositionalComplexity"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A compound pattern formed by combining multiple elementary primitives.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#CombinatorialMotif">
  <rdfs:subClassOf rdf:resource="#CompositionalComplexity"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A multi-layered pattern expanding on traditional rules, elementary and synthetic motifs.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#SymmetricalGeometry">
  <rdfs:subClassOf rdf:resource="#GeometricStructure"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A layout displaying clear mathematical reflection, rotation, or translation symmetry.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#AsymmetricalGeometry">
  <rdfs:subClassOf rdf:resource="#GeometricStructure"/>
  <subclassDefinition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A layout governed by organic, non-uniform, or balanced asymmetrical spatial constraints.</subclassDefinition>
</owl:Class>

<owl:Class rdf:about="#SemanticCulturalContext">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#DigitizedAsset">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#PointCloud">
